            drawPaths() {
                const svg = document.getElementById('viewer-svg');
                const core = document.querySelector('.molecule-core');
                if(!core || !svg) return;
                
                const cRect = core.getBoundingClientRect();
                const svgRect = svg.getBoundingClientRect();
                
                const getCoords = (el, side) => {
                    const r = el.getBoundingClientRect();
                    return {
                        x: side === 'left' ? r.left - svgRect.left : r.right - svgRect.left,
                        y: r.top - svgRect.top + r.height/2
                    };
                };

                const coreL = { x: cRect.left - svgRect.left + 10, y: cRect.top - svgRect.top + cRect.height/2 };
                const coreR = { x: cRect.right - svgRect.left - 10, y: cRect.top - svgRect.top + cRect.height/2 };

                let paths = '';
                this.state.currentChart.preparations.forEach(p => {
                    const el = document.getElementById(`v-prep-${p.id}`);
                    if(!el) return;
                    const end = getCoords(el, 'right');
                    paths += this.createCurve(end, coreL, '#8b5cf6');
                });

                this.state.currentChart.reactions.forEach(r => {
                    const el = document.getElementById(`v-rxn-${r.id}`);
                    if(!el) return;
                    const start = getCoords(el, 'left');
                    paths += this.createCurve(coreR, start, '#06b6d4');
                    
                    const rxnEnd = getCoords(el, 'right');
                    (r.observations || []).forEach(obs => {
                        const obsEl = document.getElementById(`v-obs-${obs.id}`);
                        if(obsEl) {
                            paths += this.createCurve(rxnEnd, getCoords(obsEl, 'left'), '#f97316');
                        }
                    });
                });

                svg.innerHTML = paths;
            },

            createCurve(p1, p2, color) {
                const midX = (p1.x + p2.x) / 2;
                return `<path d="M ${p1.x} ${p1.y} C ${midX} ${p1.y}, ${midX} ${p2.y}, ${p2.x} ${p2.y}" stroke="${color}" stroke-width="2" fill="none" class="path-animate" opacity="0.4" />`;
            },

            // --- STATE ACTIONS ---
            createNewChart(goBuilder = true) {
                const id = 'chart_' + Date.now();
                const defaultCat = this.state.categories[0]?.id || '';
                this.state.currentChart = {
                    id, title: '', subtext: '', categoryId: defaultCat, preparations: [], reactions: []
                };
                if(goBuilder) this.switchView('builder');
            },

            viewChart(id) {
                this.state.currentChart = this.state.charts.find(c => c.id === id);
                this.switchView('viewer');
            },

            async saveCurrentChart() {
                const c = this.state.currentChart;
                c.title = document.getElementById('build-title').value;
                c.subtext = document.getElementById('build-subtext').value;
                const catSelect = document.getElementById('build-category');
                c.categoryId = catSelect ? catSelect.value : this.state.categories[0]?.id || '';
                
                const idx = this.state.charts.findIndex(item => item.id === c.id);
                if(idx > -1) this.state.charts[idx] = JSON.parse(JSON.stringify(c));
                else this.state.charts.push(JSON.parse(JSON.stringify(c)));
                
                localStorage.setItem('chem_ultra_v1', JSON.stringify(this.state.charts));
                
                if (this.state.user && !this.state.user.isAnonymous) {
                    try {
                        const chartRef = doc(fDb, 'artifacts', 'studyflow-pro', 'users', this.state.user.uid, 'charts', c.id);
                        await setDoc(chartRef, c);
                        this.showToast("Saved to Cloud", "success");
                    } catch (e) {
                        this.showToast("Cloud save failed", "error");
                    }
                } else {
                    this.showToast("Saved Locally", "success");
                }
                
                this.switchView('dashboard');
            },

            async deleteChart(id) {
                if(confirm("Permanently delete this compound from the archive?")) {
                    this.state.charts = this.state.charts.filter(c => c.id !== id);
                    localStorage.setItem('chem_ultra_v1', JSON.stringify(this.state.charts));
                    
                    if (this.state.user && !this.state.user.isAnonymous) {
                        try {
                            const chartRef = doc(fDb, 'artifacts', 'studyflow-pro', 'users', this.state.user.uid, 'charts', id);
                            await deleteDoc(chartRef);
                        } catch (e) {
                            console.warn("Delete from cloud failed:", e);
                        }
                    }
                    
                    this.renderDashboard();
                    this.renderCategoryFilters();
                    this.showToast("Compound Purged", "error");
                }
            },

            // --- ITEM HELPERS ---
            addPrep() { this.state.currentChart.preparations.push({id: Date.now(), topText: '', mainText: ''}); this.renderBuilderItems(); },
            addReaction() { this.state.currentChart.reactions.push({id: Date.now(), reagent: '', product: '', subText: '', observations: []}); this.renderBuilderItems(); },
            addObservation(idx) { this.state.currentChart.reactions[idx].observations.push({id: Date.now(), mainText: ''}); this.renderBuilderItems(); },
            updateItem(type, idx, key, val) { this.state.currentChart[type][idx][key] = val; },
            removeItem(type, idx) { this.state.currentChart[type].splice(idx, 1); this.renderBuilderItems(); },
            updateObs(rIdx, oIdx, key, val) { this.state.currentChart.reactions[rIdx].observations[oIdx][key] = val; },
            removeObs(rIdx, oIdx) { this.state.currentChart.reactions[rIdx].observations.splice(oIdx, 1); this.renderBuilderItems(); },

            // --- INTERACTION ---
            setupKeyboard() {
                window.addEventListener('keydown', e => {
                    if(e.ctrlKey && e.key === 'k') {
                        e.preventDefault();
                        document.getElementById('command-palette').classList.toggle('open');
                        document.getElementById('cmd-input').focus();
                    }
                    if(e.key === 'Escape') document.getElementById('command-palette').classList.remove('open');
                });
            },

            setupDrag() {
                const container = document.getElementById('viewer-container');
                const wrapper = document.getElementById('viewer-wrapper');
                if (!container || !wrapper) return;
                
                container.addEventListener('mousedown', e => {
                    this.state.isDragging = true;
                    this.state.dragStart = { x: e.clientX - this.state.offset.x, y: e.clientY - this.state.offset.y };
                });
                window.addEventListener('mousemove', e => {
                    if(!this.state.isDragging || this.state.view !== 'viewer') return;
                    this.state.offset.x = e.clientX - this.state.dragStart.x;
                    this.state.offset.y = e.clientY - this.state.dragStart.y;
                    wrapper.style.transform = `translate(${this.state.offset.x}px, ${this.state.offset.y}px) scale(${this.state.zoom})`;
                });
                window.addEventListener('mouseup', () => this.state.isDragging = false);
            },

            changeZoom(delta) {
                this.state.zoom = Math.max(0.3, Math.min(2, this.state.zoom + delta));
                const zoomEl = document.getElementById('zoom-level');
                const wrapperEl = document.getElementById('viewer-wrapper');
                if (zoomEl) zoomEl.textContent = Math.round(this.state.zoom * 100) + '%';
                if (wrapperEl) wrapperEl.style.transform = `translate(${this.state.offset.x}px, ${this.state.offset.y}px) scale(${this.state.zoom})`;
            },

            showToast(msg, type) {
                const id = 't' + Date.now();
                const html = `
                    <div id="${id}" class="glass-panel px-6 py-4 rounded-2xl flex items-center gap-4 animate-fade border-l-4 ${type === 'success' ? 'border-l-cyan-500' : 'border-l-red-500'}">
                        <i data-lucide="${type === 'success' ? 'check-circle' : 'alert-circle'}" class="w-5 h-5 ${type === 'success' ? 'text-cyan-400' : 'text-red-400'}"></i>
                        <span class="text-xs font-black uppercase text-white">${msg}</span>
                    </div>
                `;
                const container = document.getElementById('toast-container');
                if (container) {
                    container.insertAdjacentHTML('beforeend', html);
                    lucide.createIcons({root: document.getElementById(id)});
                    setTimeout(() => document.getElementById(id)?.remove(), 3000);
                }
            },

            export() {
                const blob = new Blob([JSON.stringify(this.state.charts)], {type: 'application/json'});
                const url = URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = `chem_pro_backup_${Date.now()}.json`;
                a.click();
            },

            import(e) {
                const file = e.target.files[0];
                if (!file) return;
                const reader = new FileReader();
                reader.onload = (re) => {
                    try {
                        const data = JSON.parse(re.target.result);
                        this.state.charts = data;
                        localStorage.setItem('chem_ultra_v1', JSON.stringify(data));
                        
                        if (this.state.user && !this.state.user.isAnonymous) {
                            this.syncLocalToFirestore(this.state.user.uid);
                        }
                        
                        this.renderDashboard();
                        this.renderCategoryFilters();
                        this.showToast("Data Imported", "success");
                    } catch(e) {
                        this.showToast("Invalid File Format", "error");
                    }
                };
                reader.readAsText(file);
            },

            getDemoChart() {
                return {
                    id: 'demo_1', title: 'H2SO4', subtext: 'Sulfuric Acid', categoryId: 'cat_inorganic',
                    preparations: [
                        {id: 1, topText: 'Contact Process', mainText: 'SO3 + H2O'},
                        {id: 2, topText: 'Lead Chamber', mainText: 'SO2 + NO2 + H2O'}
                    ],
                    reactions: [
                        {id: 1, reagent: 'Sugar (C12H22O11)', product: 'Carbon (C)', subText: 'Dehydration (Black Mass)', observations: [{id: 1, mainText: 'Steam Evolved'}]},
                        {id: 2, reagent: 'BaCl2', product: 'BaSO4', subText: 'White Precipitate', observations: [{id: 2, mainText: 'Insoluble in HCl'}]}
                    ]
                };
            }
        };

        window.onload = () => app.init();
    </script>
</body>
</html>
