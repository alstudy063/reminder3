    <!-- App Logic Module -->
    <script type="module">
        const { 
            signInAnonymously, onAuthStateChanged, GoogleAuthProvider, 
            signInWithPopup, signOut, collection, doc, setDoc, deleteDoc, onSnapshot, writeBatch 
        } = window.FirebaseModules;
        const fAuth = window.firebaseAuth;
        const fDb = window.firebaseDb;

        window.app = {
            state: {
                view: 'dashboard',
                user: null,
                charts: [],
                categories: [], // array of { id, name }
                selectedCategoryId: 'all', // 'all' or category id
                currentChart: null,
                zoom: 1,
                isDragging: false,
                dragStart: { x: 0, y: 0 },
                offset: { x: 0, y: 0 },
                firestoreUnsubscribe: null,
                isOnline: true
            },
            firebase: { auth: fAuth, db: fDb },

            async init() {
                this.setupKeyboard();
                this.setupDrag();
                
                // Load categories from localStorage or init defaults
                const storedCats = localStorage.getItem('chem_categories');
                if (storedCats) {
                    this.state.categories = JSON.parse(storedCats);
                } else {
                    this.state.categories = [
                        { id: 'cat_all', name: 'All' }, // special, but we'll handle in filters
                        { id: 'cat_organic', name: 'Organic' },
                        { id: 'cat_inorganic', name: 'Inorganic' }
                    ];
                    localStorage.setItem('chem_categories', JSON.stringify(this.state.categories));
                }
                
                // Load charts
                const local = localStorage.getItem('chem_ultra_v1');
                if(!local) {
                    this.state.charts = [this.getDemoChart()];
                    localStorage.setItem('chem_ultra_v1', JSON.stringify(this.state.charts));
                } else {
                    this.state.charts = JSON.parse(local);
                }

                this.renderDashboard();
                this.renderCategoryFilters();
                this.renderCategorySelect();
                lucide.createIcons();
                
                // Set up auth state listener
                onAuthStateChanged(fAuth, async (user) => {
                    this.state.user = user;
                    this.updateUserUI();
                    
                    if (this.state.firestoreUnsubscribe) {
                        this.state.firestoreUnsubscribe();
                        this.state.firestoreUnsubscribe = null;
                    }
                    
                    if (user) {
                        const chartsRef = collection(fDb, 'artifacts', 'studyflow-pro', 'users', user.uid, 'charts');
                        this.state.firestoreUnsubscribe = onSnapshot(chartsRef, (snapshot) => {
                            const firestoreCharts = [];
                            snapshot.forEach(doc => {
                                firestoreCharts.push({ id: doc.id, ...doc.data() });
                            });
                            if (firestoreCharts.length > 0 || snapshot.metadata.hasPendingWrites) {
                                this.state.charts = firestoreCharts;
                                localStorage.setItem('chem_ultra_v1', JSON.stringify(firestoreCharts));
                                this.renderDashboard();
                                this.renderCategoryFilters();
                                this.renderCategorySelect();
                                lucide.createIcons();
                            } else {
                                this.syncLocalToFirestore(user.uid);
                            }
                        }, (error) => {
                            console.warn("Firestore offline:", error);
                            this.state.isOnline = false;
                            this.updateSyncStatus();
                        });
                    } else {
                        this.state.isOnline = false;
                        this.updateSyncStatus();
                    }
                });

                try {
                    await signInAnonymously(fAuth);
                } catch (e) {
                    console.warn("Anon sign-in skipped:", e);
                }

                // Initialize theme from localStorage
                const savedTheme = localStorage.getItem('theme') || 'dark';
                if (savedTheme === 'light') {
                    document.documentElement.classList.add('light');
                    document.getElementById('theme-toggle-btn').textContent = 'Switch to Dark';
                }
            },

            // Theme toggle
            toggleTheme() {
                const html = document.documentElement;
                const btn = document.getElementById('theme-toggle-btn');
                if (html.classList.contains('light')) {
                    html.classList.remove('light');
                    btn.textContent = 'Switch to Light';
                    localStorage.setItem('theme', 'dark');
                } else {
                    html.classList.add('light');
                    btn.textContent = 'Switch to Dark';
                    localStorage.setItem('theme', 'light');
                }
            },

            // Category management
            addCategory() {
                const input = document.getElementById('new-category-input');
                const name = input.value.trim();
                if (!name) return;
                // Prevent duplicate names (case insensitive)
                if (this.state.categories.some(c => c.name.toLowerCase() === name.toLowerCase())) {
                    this.showToast('Category already exists', 'error');
                    return;
                }
                const newCat = { id: 'cat_' + Date.now(), name };
                this.state.categories.push(newCat);
                localStorage.setItem('chem_categories', JSON.stringify(this.state.categories));
                this.renderCategoryList();
                this.renderCategoryFilters();
                this.renderCategorySelect();
                input.value = '';
                this.showToast('Category added', 'success');
            },

            deleteCategory(id) {
                // Prevent deletion if any chart uses this category
                const used = this.state.charts.some(c => c.categoryId === id);
                if (used) {
                    this.showToast('Cannot delete category in use', 'error');
                    return;
                }
                this.state.categories = this.state.categories.filter(c => c.id !== id);
                localStorage.setItem('chem_categories', JSON.stringify(this.state.categories));
                this.renderCategoryList();
                this.renderCategoryFilters();
                this.renderCategorySelect();
                this.showToast('Category removed', 'success');
            },

            renderCategoryList() {
                const container = document.getElementById('category-list');
