        import { getAuth, signInAnonymously, onAuthStateChanged, GoogleAuthProvider, signInWithPopup, signOut } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-auth.js";
        import { getFirestore, collection, doc, setDoc, deleteDoc, onSnapshot, writeBatch } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js";

        const firebaseConfig = {
            apiKey: "AIzaSyA9DLfAHTUUGxCPn2j_k6godoTEopzaFAU",
            authDomain: "studymaster-919ba.firebaseapp.com",
            databaseURL: "https://studymaster-919ba-default-rtdb.firebaseio.com",
            projectId: "studymaster-919ba",
            storageBucket: "studymaster-919ba.firebasestorage.app",
            messagingSenderId: "426684063256",
            appId: "1:426684063256:web:52c17625a9450ea9662d6d",
            measurementId: "G-CWQB2330GF"
        };

        const fApp = initializeApp(firebaseConfig);
        const analytics = getAnalytics(fApp);
        const fAuth = getAuth(fApp);
        const fDb = getFirestore(fApp);

        window.firebaseApp = fApp;
        window.firebaseAuth = fAuth;
        window.firebaseDb = fDb;

        window.FirebaseModules = {
            signInAnonymously,
            onAuthStateChanged,
            GoogleAuthProvider,
            signInWithPopup,
            signOut,
            collection,
            doc,
            setDoc,
            deleteDoc,
            onSnapshot,
            writeBatch
        };
    </script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap');

        :root {
            --accent: #06b6d4;
            --accent-glow: rgba(6, 182, 212, 0.4);
            --bg-glass: rgba(15, 23, 42, 0.7);
            --border-glass: rgba(255, 255, 255, 0.08);
            --font-main: 'Plus Jakarta Sans', sans-serif;
            --bg-primary: #0f172a;
            --text-primary: #f8fafc;
            --text-secondary: rgba(255,255,255,0.5);
        }

        /* Light theme overrides */
        html.light {
            --accent: #0284c7;
            --accent-glow: rgba(2, 132, 199, 0.3);
            --bg-glass: rgba(255, 255, 255, 0.85);
            --border-glass: rgba(0, 0, 0, 0.08);
            --bg-primary: #f1f5f9;
            --text-primary: #0f172a;
            --text-secondary: rgba(15, 23, 42, 0.6);
            background: #f8fafc;
        }

        body {
            font-family: var(--font-main);
            background: radial-gradient(circle at top right, #1e293b, #0f172a, #020617);
            color: var(--text-primary);
            overflow: hidden;
            height: 100vh;
        }

        html.light body {
            background: radial-gradient(circle at top right, #e2e8f0, #cbd5e1, #94a3b8);
        }

        /* Glassmorphism Classes */
        .glass-panel {
            background: var(--bg-glass);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid var(--border-glass);
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
        }

        .glass-card {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(8px);
            border: 1px solid rgba(255, 255, 255, 0.05);
            transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
        }

        html.light .glass-card {
            background: rgba(0, 0, 0, 0.02);
            border: 1px solid rgba(0, 0, 0, 0.05);
        }

        .glass-card:hover {
            background: rgba(255, 255, 255, 0.07);
            transform: translateY(-5px);
            border-color: var(--accent);
            box-shadow: 0 10px 40px -10px var(--accent-glow);
        }

        html.light .glass-card:hover {
            background: rgba(0, 0, 0, 0.05);
        }

        /* Smooth Animations */
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes drawLine { from { stroke-dashoffset: 1000; } to { stroke-dashoffset: 0; } }
        @keyframes pulseGlow { 0%, 100% { box-shadow: 0 0 20px var(--accent-glow); } 50% { box-shadow: 0 0 40px var(--accent); } }
        @keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }

        .animate-fade { animation: fadeIn 0.5s forwards; }
        .path-animate { stroke-dasharray: 1000; stroke-dashoffset: 1000; animation: drawLine 2s ease-out forwards; }
        .glow-pulse { animation: pulseGlow 3s infinite; }
        .float-animation { animation: float 6s ease-in-out infinite; }

        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.1); border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: var(--accent); }

        .view-section { display: none; opacity: 0; transition: opacity 0.3s ease; }
        .view-section.active { display: flex; opacity: 1; }

        /* Molecule Node styling */
        .molecule-core {
            background: conic-gradient(from 180deg at 50% 50%, #06b6d4 0deg, #3b82f6 120deg, #8b5cf6 240deg, #06b6d4 360deg);
            position: relative;
        }
        .molecule-core::after {
            content: '';
            position: absolute;
            inset: 4px;
            background: var(--bg-primary);
            border-radius: 50%;
            z-index: 1;
        }

        /* Command Palette Style */
        #command-palette {
            transform: translate(-50%, -120%);
            transition: transform 0.3s cubic-bezier(0.19, 1, 0.22, 1);
        }
        #command-palette.open { transform: translate(-50%, 20px); }

        input:focus, select:focus {
            outline: none;
            box-shadow: 0 0 0 2px var(--accent-glow);
        }

        /* Light mode text adjustments */
        html.light .text-white { color: #0f172a !important; }
        html.light .text-white\/50 { color: rgba(15, 23, 42, 0.5) !important; }
        html.light .text-white\/70 { color: rgba(15, 23, 42, 0.7) !important; }
        html.light .bg-white\/5 { background: rgba(0, 0, 0, 0.03) !important; }
        html.light .border-white\/5 { border-color: rgba(0, 0, 0, 0.05) !important; }
        html.light .border-white\/10 { border-color: rgba(0, 0, 0, 0.1) !important; }
        html.light .placeholder\:text-white\/20::placeholder { color: rgba(15, 23, 42, 0.2) !important; }
        html.light .placeholder\:text-white\/40::placeholder { color: rgba(15, 23, 42, 0.4) !important; }
    </style>
</head>
