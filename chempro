            async syncLocalToFirestore(uid) {
                if (!uid) return;
                const batch = writeBatch(fDb);
                const chartsRef = collection(fDb, 'artifacts', 'studyflow-pro', 'users', uid, 'charts');
                this.state.charts.forEach(chart => {
                    const chartDoc = doc(chartsRef, chart.id);
                    batch.set(chartDoc, chart);
                });
                try {
                    await batch.commit();
                    this.showToast("Local data uploaded", "success");
                } catch (e) {
                    console.error("Sync failed:", e);
                }
            },

            updateUserUI() {
                const nameEl = document.getElementById('user-display-name');
                const initialsEl = document.getElementById('user-initials');
                const setUserNameEl = document.getElementById('set-user-name');
                const signinBtn = document.getElementById('signin-btn');
